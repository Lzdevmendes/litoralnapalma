# Copie este arquivo para .env.local e preencha com suas chaves.
# Nenhuma variável é obrigatória — sem elas o app roda com dados mock.

# ─── Supabase ───────────────────────────────────────────────────────────────
# Projeto: https://supabase.com/dashboard
# Configurações em: Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OpenWeatherMap ──────────────────────────────────────────────────────────
# Crie uma chave em: https://openweathermap.org/api
# Plano gratuito cobre /weather (temperatura, condição, vento, umidade).
# Índice UV (/onecall) requer plano pago — One Call API 3.0.
EXPO_PUBLIC_OPENWEATHER_KEY=sua_chave_aqui

# ─── Google Maps API ─────────────────────────────────────────────────────────
# Habilite "Maps SDK for Android" e "Maps SDK for iOS" em:
# https://console.cloud.google.com
# Necessário para react-native-maps funcionar em dev build.
# No Expo Go o mapa usa Leaflet (WebView) e NÃO precisa desta chave.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=sua_chave_aqui

# ─── Google Routes API ───────────────────────────────────────────────────────
# Chave da Routes API agora fica como Supabase secret — não vai para o bundle.
# Configure com: supabase secrets set GOOGLE_ROUTES_KEY=sua_chave_aqui
# (Habilite "Routes API" em console.cloud.google.com)

# ─── Google OAuth (opcional) ─────────────────────────────────────────────────
# Necessário apenas se implementar login com Google via expo-auth-session.
# Crie um OAuth 2.0 Client ID (tipo: iOS/Android) em: https://console.cloud.google.com
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
