{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/components/*": ["./components/*"],
      "@/lib/*": ["./lib/*"],
      "@/hooks/*": ["./hooks/*"],
      "@/data/*": ["./data/*"],
      "@/context/*": ["./context/*"]
    }
  },
  "exclude": ["node_modules", "supabase/functions", "__tests__"]
}
